APP_NAME="Ecovasos Store"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://verdenova.com.br
APP_ADMIN_URL=admin

APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_CURRENCY=BRL

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ecovasos
DB_USERNAME=ecovasos
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

ELASTICSEARCH_HOST=http://elasticsearch:9200

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@verdenova.com.br"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
MELHOR_ENVIO_TOKEN=

BCRYPT_ROUNDS=12

RUN_MIGRATIONS=false
